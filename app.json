{
  "expo": {
    "name": "Xará",
    "slug": "setophaga-expo",
    "version": "0.1",
    "scheme": "setophaga-expo",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://xara-roan.vercel.app"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "reactCompiler": true,
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "orientation": "portrait",
    "icon": "./assets/icon-borda.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/xara-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFBF7"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "associatedDomains": ["applinks:xara-roan.vercel.app"]
    },
    "android": {
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "xara-roan.vercel.app"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-borda.png",
        "backgroundColor": "#FFFBF7"
      },
      "package": "br.com.xara"
    },
    "extra": {
      "router": {
        "origin": "https://xara-roan.vercel.app"
      },
      "eas": {
        "projectId": "0d3d31fb-03c8-4fea-a60d-9b6742df408c"
      }
    }
  }
}
