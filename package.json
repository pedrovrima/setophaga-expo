{
  "name": "setophaga-expo",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "aab": "./scripts/build-android-aab.sh",
    "apk": "./scripts/build-android-apk-eas.sh preview",
    "apk:debug": "./scripts/build-android-apk.sh debug",
    "apk:eas": "./scripts/build-android-apk-eas.sh preview",
    "apk:local": "./scripts/build-android-apk.sh release",
    "apk:local:debug": "./scripts/build-android-apk.sh debug",
    "apk:release": "./scripts/build-android-apk-eas.sh preview",
    "android": "expo run:android",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "ios": "expo run:ios",
    "postinstall": "[ \"$VERCEL\" = \"1\" ] || ./scripts/patch-react-native-gradle-plugin.sh || true",
    "prebuild:android": "expo prebuild --platform android --no-install",
    "start": "expo start",
    "web": "expo start --web",
    "vercel-build": "expo export -p web"
  },
